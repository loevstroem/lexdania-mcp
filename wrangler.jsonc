{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lexdania-mcp",
  "account_id": "2e0dda3b3fbe17f0c0a765a46287fbcd",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": ["nodejs_compat"],
  "minify": true,
  "keep_names": false,
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "lexdania.pacmate.dk",
      "custom_domain": true
    }
  ],
  // Workers Caching: the gateway (default export) always runs; only the
  // DocumentResolver loopback entrypoint is served through the cache.
  "cache": {
    "enabled": true
  },
  "exports": {
    "default": { "type": "worker", "cache": { "enabled": false } },
    "DocumentResolver": { "type": "worker", "cache": { "enabled": true } }
  },
  "vars": {
    "GEMINI_MODEL": "gemini-3.5-flash"
  },
  "limits": {
    "cpu_ms": 300000,
    "subrequests": 1000
  }
}
